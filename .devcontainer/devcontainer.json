{
  "name": "Android Build Environment",
  "dockerFile": "Dockerfile",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },
  "postCreateCommand": "bash /usr/local/bin/setup-android.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "vscjava.vscode-java-pack",
        "redhat.java"
      ]
    }
  }
}
